{
  "namespace": "chest",
  "chest_label": {
    "$display_title|default": "$container_title",
    "text": "$display_title"
  },
  "small_chest_screen": {
    "$display_title|default": "$container_title",
    "$container_size|default": 27,
    "modifications": [
      {
        "array_name": "variables",
        "operation": "insert_back",
        "value": {
          "requires": "($display_title = 'tfcla:ui_knapping')",
          "$screen_content": "knapping.ui_root",
          "$screen_bg_content": "common.screen_background",
          "$display_title": "ui.tfcla:knapping.rock.title",
          "$container_size": 52
        }
      }
    ]
  }
}