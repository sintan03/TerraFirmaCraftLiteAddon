{
    "namespace":"util",
    "slot": {
        "size": [
            18,
            18
        ],
        "type": "collection_panel",
        "anchor_from": "center",
        "anchor_to": "center",
        "$start_index|default": 0,
        "collection_name": "container_items",
        "controls": [
            {
                "slot_item@chest.chest_grid_item": {
                    "anchor_from": "center",
                    "anchor_to": "center",
                    "collection_index": "$start_index",
                    "$button_ref": "util.slot_name_only",
                    "offset": [
                        0,
                        0
                    ],
                    "$cell_image_size|default": [
                        18,
                        18
                    ],
                    "size": [
                        18,
                        18
                    ]
                }
            }
        ]
    },
    "slot_focus_none": {
        "type": "button"
    },
    "slot_name_only": {
        "type": "button",
        "$focus_id|default": "",
        "$focus_override_down|default": "",
        "$focus_override_up|default": "",
        "$focus_override_left|default": "",
        "$focus_override_right|default": "",
        "$focus_id_binding_type|default": "collection",
        "$focus_override_down_binding_type|default": "collection",
        "$focus_override_up_binding_type|default": "collection",
        "$focus_override_left_binding_type|default": "collection",
        "$focus_override_right_binding_type|default": "collection",
        "focus_identifier": "$focus_id",
        "focus_enabled": true,
        "focus_wrap_enabled": false,
        "focus_magnet_enabled": true,
        "$highlight_control|default": "common.highlight_slot_panel",
        "default_focus_precedence": 1,
        "hover_control": "hover",
        "layer": 1,
        "controls": [
            {
                "hover@$highlight_control": {}
            }
        ]
    }
}